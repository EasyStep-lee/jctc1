{
  "name": "jctc1",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "25.8.1",
    "pnpm": "10.12.1"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:api": "pnpm --filter @jctc/api test",
    "test:e2e:p0": "playwright test",
    "monorepo:check": "node scripts/check-monorepo-structure.mjs",
    "prisma:validate": "pnpm --filter @jctc/db prisma:validate",
    "prisma:migrate:dry-run": "pnpm --filter @jctc/db prisma:migrate:dry-run",
    "openapi:check": "pnpm --filter @jctc/openapi-client openapi:check",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm prisma:validate && pnpm openapi:check && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.6.0",
    "turbo": "^2.7.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}

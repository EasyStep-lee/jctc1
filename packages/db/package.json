{
  "name": "@jctc/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prisma:validate": "node scripts/run-prisma.mjs validate --schema prisma/schema.prisma",
    "prisma:migrate:dry-run": "node scripts/run-prisma.mjs migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script"
  },
  "dependencies": {
    "@prisma/client": "6.19.0"
  },
  "devDependencies": {
    "prisma": "6.19.0"
  }
}
